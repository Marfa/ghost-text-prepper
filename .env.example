GHOST_URL=https://your-site.ghost.io
GHOST_ADMIN_API_KEY=id:secret

# Hugging Face token with Inference Providers access
# Must start with hf_ (not hhf_ or other typos)
HF_TOKEN=hf_xxx
HF_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct

# Bonsai Image Demo (FastAPI Space)
BONSAI_URL=https://prism-ml-bonsai-image-demo.hf.space
BONSAI_BACKEND=bonsai-ternary-gemlite
BONSAI_SEED=42
BONSAI_STEPS=4
BONSAI_WIDTH=1248
BONSAI_HEIGHT=832
# Optional: Bearer token if the Space starts requiring auth
BONSAI_TOKEN=

MAX_EXCERPT_LEN=146
# Skip drafts that already have both excerpt and feature image (1/0)
SKIP_COMPLETE=1

# Timestamp of last successful run (updated by app + GitHub Action)
STATE_FILE=state/last-run.json
